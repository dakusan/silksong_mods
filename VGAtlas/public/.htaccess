<FilesMatch "^index\.html$">
	Header set Cache-Control "no-cache"
</FilesMatch>

RewriteEngine On
RewriteCond %{REQUEST_URI} /assets/.+\.[A-Za-z0-9_-]{8,}\.(js|css|png|jpg|jpeg|gif|svg|ico|json)$
RewriteRule ^ - [E=IS_HASHED:1]
Header set Cache-Control "public, max-age=31536000, immutable" env=IS_HASHED