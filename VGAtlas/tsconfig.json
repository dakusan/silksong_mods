{
	"compilerOptions": {
		"target"			: "ES2022",
		"module"			: "ESNext",
		"moduleResolution"	: "Bundler",
		"sourceMap"			: true,
		"inlineSources"		: true,
		"noEmit"			: true,
		"skipLibCheck"		: true,

		//Type checking
		"strict"			: true, //noImplicitAny, noImplicitThis, strictNullChecks, strictFunctionTypes, strictBindCallApply, strictPropertyInitialization, useUnknownInCatchVariables, alwaysStrict
		"alwaysStrict"		: true,
		"noImplicitOverride": true,
		"noImplicitReturns"	: true,
		"noUnusedLocals"	: true,
		"noUnusedParameters": true,

		//Interop/Emit
		"experimentalDecorators": true,
		"newLine"			: "LF",
	},
	"include": ["src"],
}