{
	"compilerOptions": {
		"target"			: "ESNext",
		"module"			: "NodeNext",
		"moduleResolution"	: "NodeNext",
		"sourceMap"			: true,
		"skipLibCheck"		: true,
		"rootDir"			: "src",
		"outDir"			: "gen",

		//Type checking
		"strict"			: true, //noImplicitAny, noImplicitThis, strictNullChecks, strictFunctionTypes, strictBindCallApply, strictPropertyInitialization, useUnknownInCatchVariables, alwaysStrict
		"noImplicitOverride": true,
		"noImplicitReturns"	: true,
		"noUnusedLocals"	: true,
		"noUnusedParameters": true,
		"isolatedModules"	: true,
		"verbatimModuleSyntax"			: true,
		"noUncheckedSideEffectImports"	: true,
		"moduleDetection"				: "force",

		//Interop/Emit
		"newLine"			: "LF",

		"types"				: ["node"],
		"lib"				: ["ESNext"],
	},
}