{
	"name": "VGAtlas Server",
	"author": "Dakusan",
	"license": "BSD-3-Clause",
	"version": "1.0.0",
	"description": "Live video game map viewing and editing of curios",
	"main": "index.js",
	"type": "module",
	"private": true,
	"scripts": {
		"typecheck": "tsc --noEmit",
		"dev": "tsx src/index.ts",
		"build": "tsc",
		"start": "node --enable-source-maps dist/index.js"
	},
	"keywords": [
		"Video Game",
		"VG",
		"Map",
		"Atlas"
	],
	"devDependencies": {
		"@types/node": "^25.9.2",
		"@types/ws": "^8.18.1",
		"eslint": "^10.4.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0"
	},
	"dependencies": {
		"ws": "^8.21.0"
	}
}